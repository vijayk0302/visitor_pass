<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      body {
        margin: 0;
        background: white;
        font-family: Arial, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .container {
        position: relative;
      }

      .card {
        width: 360px;
        height: 520px;
        background: #111827;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        border-radius: 6px;
      }

      .brand {
        color: white;
        padding: 50px;
        font-size: 20px;
        font-weight: bold;
      }

      .yellow-bottom {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 50%;
        background: #f59e0b;
      }

      .white-diagonal {
        position: absolute;
        width: 800px;
        height: 250px;
        background: white;
        top: 305px;
        right: -151px;
        transform: rotate(-45deg);
      }

      .yellow-box {
        position: absolute;
        width: 160px;
        height: 160px;
        background: #f59e0b;
        top: -79px;
        right: -79px;
        transform: rotate(-45deg);
      }

      .side-text {
        position: absolute;
        bottom: 60px;
        left: 10px;
        transform: rotate(-90deg);
        font-weight: bold;
        color: #111827;
        font-size: 14px;
      }

      .content {
        text-align: center;
        position: relative;
        z-index: 10;
        text-align: center;
        margin-top: 20px;
      }

      .photo {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
      }

      .name {
        margin-top: 10px;
        font-size: 18px;
        font-weight: bold;
        color: #111827;
      }

      .text {
        margin-top: 8px;
        font-size: 12px;
        font-weight: bold;
        color: #111827;
      }

      .qr {
        width: 120px;
        margin-top: 10px;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="card">
        <div class="brand">Visi.co</div>

        <div class="yellow-bottom"></div>
        <div class="white-diagonal"></div>
        <div class="yellow-box"></div>

        <div class="side-text">
          <div><%= pass.status %></div>
          <div>Issuer: <%= pass.issuedBy.name %></div>
        </div>

        <div class="content">
          <img class="photo" src="<%= pass.appointment.photo %>" />

          <div class="name"><%= pass.appointment.visitor.name %></div>

          <div class="text">VISITOR'S PASS</div>

          <div class="text"><%= pass.appointment.purpose %></div>

          <div class="text"><%= new Date(pass.validFrom).toLocaleDateString() %></div>

          <img class="qr" src="<%= pass.qrCode %>" />
        </div>
      </div>
    </div>
  </body>
</html>
